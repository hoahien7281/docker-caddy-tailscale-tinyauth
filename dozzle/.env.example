# =============================================================================
# dozzle/.env.example — Dozzle Docker log viewer
# =============================================================================
#
# Docs:
#   - https://dozzle.dev/
#   - https://hub.docker.com/r/amir20/dozzle
#
# Profiles: dozzle | full
# =============================================================================

# DOMAIN
#   Default DOZZLE_HOST = http://dozzle.${DOMAIN}
DOMAIN=example.com

# DOZZLE_HOST
#   Caddy site address. Use http:// because TLS terminates at Cloudflare/Tailscale.
#   Protects with caddy.import: tinyauth_forwarder * in dozzle/dozzle.yml.
DOZZLE_HOST=http://dozzle.example.com
