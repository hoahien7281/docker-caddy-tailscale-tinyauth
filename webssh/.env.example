# =============================================================================
# webssh/.env.example — browser terminal backed by ttyd + tmux
# =============================================================================
#
# Docs:
#   - https://github.com/tsl0922/ttyd
#   - https://github.com/tmux/tmux/wiki
#
# Profiles: webssh | full
# =============================================================================

# DOMAIN
#   Default WEBSSH_HOST = http://ttyd.${DOMAIN}
DOMAIN=example.com

# WEBSSH_HOST
#   Caddy site address. Use http:// because TLS terminates at Cloudflare/Tailscale.
#   The service is protected by Tinyauth.
WEBSSH_HOST=http://ttyd.example.com

# Session behavior:
#   webssh starts `tmux new-session -A -s webssh`.
#   Closing the browser detaches; reopening attaches to the same tmux session.
#   The repository root is mounted at /workspace, including hidden files.
