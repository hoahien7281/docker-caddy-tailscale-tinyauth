# NodeSync SSH automation. Disabled by default.
SSH_ENABLE=0
SSH_SYNC_SMOKE_ENABLE=0
SSH_SYNC_PATHS=

# Independent transports. Smoke mode executes every enabled channel in parallel.
SSH_CHANNEL_TAILSCALE_ENABLE=1
SSH_CHANNEL_CLOUDFLARE_ENABLE=0
SSH_CHANNEL_HYBRID_ENABLE=0

# Indexed users. `npm run ssh:env --prefix nodesync` creates SSH_1_USER/PASS
# automatically when none exist, generates a shared client key, groups all SSH_*
# keys together in sorted order, and masks secrets on GitHub/Azure.
# SSH_1_USER=nodesync
# SSH_1_PASS=<secret>
# SSH_1_PRIVILEGED=1
# SSH_1_PRIVATE_KEY_B64=1
# SSH_1_PRIVATE_KEY=<base64-ed25519-private-key>
# SSH_1_PUBLIC_KEY_B64=1
# SSH_1_PUBLIC_KEY=<base64-ed25519-public-key>

# Runtime paths normally generated by ssh-setup-env.mjs.
# SSH_WORKSPACE=/workspace
# SSH_RUNTIME_DIR=/runtime
# SSH_KEY_FILE=/runtime/id_ed25519
# SSH_PREDECESSOR_FILE=/runtime/predecessor.json

# Cloudflare Access Service Auth. provision-tunnel.mjs creates these using
# CF_API_EMAIL + CF_API_KEY_GLOBAL (or CF_API_TOKEN) and groups them with CF_*.
# CF_SSH_TUNNEL_SERVICE_TOKEN_NAME=example.com-nodesync-ssh
# CF_SSH_TUNNEL_SERVICE_TOKEN_ID=<client-id>
# CF_SSH_TUNNEL_SERVICE_TOKEN_SECRET=<client-secret>
