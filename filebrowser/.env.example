# =============================================================================
# filebrowser/.env.example — File Browser for the repository workspace
# =============================================================================
#
# Docs:
#   - https://filebrowser.org/
#   - https://hub.docker.com/r/filebrowser/filebrowser
#
# Profiles: filebrowser | full
# =============================================================================

# DOMAIN
#   Default FILEBROWSER_HOST = http://files.${DOMAIN}
DOMAIN=example.com

# FILEBROWSER_HOST
#   Caddy site address. Use http:// because TLS terminates at Cloudflare/Tailscale.
#   The service is protected by Tinyauth; File Browser itself runs with --noauth.
FILEBROWSER_HOST=http://files.example.com

# Workspace mount behavior:
#   filebrowser/filebrowser.yml mounts the repository root at /srv.
#   Hidden files are visible. No built-in exclude for .git or node_modules is set.
