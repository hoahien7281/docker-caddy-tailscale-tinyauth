# =============================================================================
# __APP_NAME__/.env.example — app config catalog (type: image)
# =============================================================================
#
# RULE: every key here MUST start with the app prefix __APP_PREFIX___
#       (shared infra keys allowed: DOMAIN, DOCKER_VOLUME_*, COMPOSE_PROFILES,
#        CADDY_*, TINYAUTH_*). Enforced by scripts/validate-app.mjs.
#
# Copy only the keys you actually set into the ROOT .env. Keep unused optionals
# COMMENTED OUT here — never leave bare `KEY=` (empty-string injection bug).
# =============================================================================

# -----------------------------------------------------------------------------
# Profiles (set in ROOT .env)
# -----------------------------------------------------------------------------
# COMPOSE_PROFILES=core,__APP_NAME__
# COMPOSE_PROFILES=full

# DOMAIN — root domain; default host = http://__APP_SLUG__.${DOMAIN}
DOMAIN=example.com

# __APP_PREFIX___IMAGE
#   Upstream image + tag to run. PIN a version, not :latest, in production.
__APP_PREFIX___IMAGE=CHANGE_ME/image:1.0.0

# __APP_PREFIX___HOST
#   Caddy site address for this app. Use http:// (TLS terminates at the Tunnel).
#   Must match the tunnel Public Hostname (Service URL http://caddy:80).
__APP_PREFIX___HOST=http://__APP_SLUG__.example.com

# __APP_PREFIX___PORT (reference)
#   Internal container port Caddy proxies to. Wired in __APP_NAME__.yml as
#   `{{upstreams __APP_PORT__}}`. Change the YAML label if you change this.
# __APP_PREFIX___PORT=__APP_PORT__

# -----------------------------------------------------------------------------
# App-specific env — add your own, ALL prefixed __APP_PREFIX___
# -----------------------------------------------------------------------------
# __APP_PREFIX___LOG_LEVEL=info
# __APP_PREFIX___API_KEY=your-secret-here
