# =============================================================================
# __APP_NAME__/.env.example — app config catalog (type: npx / npm)
# =============================================================================
#
# RULE: every key MUST start with __APP_PREFIX___ (shared infra keys allowed:
#       DOMAIN, DOCKER_VOLUME_*, COMPOSE_PROFILES, CADDY_*, TINYAUTH_*).
#       Enforced by scripts/validate-app.mjs.
# Copy only what you set into ROOT .env. Keep unused optionals COMMENTED.
# =============================================================================

# Profiles (ROOT .env)
# COMPOSE_PROFILES=core,__APP_NAME__

DOMAIN=example.com

# __APP_PREFIX___HOST — Caddy site address (http://; TLS at the Tunnel)
__APP_PREFIX___HOST=http://__APP_SLUG__.example.com

# __APP_PREFIX___NODE_IMAGE — base node image (pin a major version)
__APP_PREFIX___NODE_IMAGE=node:22-alpine

# __APP_PREFIX___NPX_PACKAGE — npm package to run via `npx -y`
__APP_PREFIX___NPX_PACKAGE=http-server

# __APP_PREFIX___NPX_ARGS — args passed after the package name.
#   Must make the process listen on 0.0.0.0:__APP_PORT__.
__APP_PREFIX___NPX_ARGS=. -p __APP_PORT__ -a 0.0.0.0

# __APP_PREFIX___PORT (reference) — internal listen port, wired in the YAML label
# __APP_PREFIX___PORT=__APP_PORT__

# -----------------------------------------------------------------------------
# App-specific env — ALL prefixed __APP_PREFIX___
# -----------------------------------------------------------------------------
# __APP_PREFIX___LOG_LEVEL=info
