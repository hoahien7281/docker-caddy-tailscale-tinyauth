# =============================================================================
# __APP_NAME__/.env.example — app config catalog (type: code)
# =============================================================================
#
# RULE: every key MUST start with __APP_PREFIX___ (shared infra keys allowed:
#       DOMAIN, DOCKER_VOLUME_*, COMPOSE_PROFILES, CADDY_*, TINYAUTH_*).
#       Enforced by scripts/validate-app.mjs.
# Copy only what you set into ROOT .env. Keep unused optionals COMMENTED.
# =============================================================================

# Profiles (ROOT .env)
# COMPOSE_PROFILES=core,__APP_NAME__

DOMAIN=example.com

# __APP_PREFIX___HOST — Caddy site address (http://; TLS at the Tunnel)
__APP_PREFIX___HOST=http://__APP_SLUG__.example.com

# __APP_PREFIX___PORT — internal listen port (read by app/server.mjs + label)
__APP_PREFIX___PORT=__APP_PORT__

# -----------------------------------------------------------------------------
# App-specific env — ALL prefixed __APP_PREFIX___
# -----------------------------------------------------------------------------
# __APP_PREFIX___LOG_LEVEL=info
# __APP_PREFIX___DB_URL=...
