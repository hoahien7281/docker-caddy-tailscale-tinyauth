# =============================================================================
# __APP_NAME__/.env.example — app config catalog (type: dockerfile)
# =============================================================================
#
# RULE: every key here MUST start with __APP_PREFIX___ (shared infra keys
#       allowed: DOMAIN, DOCKER_VOLUME_*, COMPOSE_PROFILES, CADDY_*, TINYAUTH_*).
#       Enforced by scripts/validate-app.mjs.
# Copy only the keys you set into the ROOT .env. Keep unused optionals COMMENTED.
# =============================================================================

# Profiles (set in ROOT .env)
# COMPOSE_PROFILES=core,__APP_NAME__

DOMAIN=example.com

# __APP_PREFIX___HOST — Caddy site address (http://; TLS at the Tunnel)
__APP_PREFIX___HOST=http://__APP_SLUG__.example.com

# __APP_PREFIX___PORT (reference) — internal listen port, wired in the YAML label
# __APP_PREFIX___PORT=__APP_PORT__

# -----------------------------------------------------------------------------
# App-specific env — ALL prefixed __APP_PREFIX___
# -----------------------------------------------------------------------------
# __APP_PREFIX___LOG_LEVEL=info
